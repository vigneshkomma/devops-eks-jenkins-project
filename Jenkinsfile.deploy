pipeline{
    agent{
        label 'jenkins-woker'
    }

    stages{
        stage('Deploy k8s'){
            steps{
                sh '''
                    helm upgrade --install devops-app \
                    kubernetes/helm/devops-app \
                    --set image.repository=vigneshop/devops-app \
                    --set image.tag=latest

                    kubectl rollout status deployment/devops-app
                '''
            }
        }
    }
}